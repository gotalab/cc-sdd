{
  "version": 1,
  "artifacts": [
    {
      "id": "skills",
      "source": {
        "type": "templateDir",
        "fromDir": "templates/agents/{{AGENT}}/skills",
        "toDir": "{{AGENT_COMMANDS_DIR}}"
      },
      "when": { "agent": "cursor-skills" }
    },
    {
      "id": "doc_main",
      "source": {
        "type": "templateFile",
        "from": "templates/agents/{{AGENT}}/docs/AGENTS.md",
        "toDir": ".",
        "rename": "{{AGENT_DOC}}"
      },
      "when": { "agent": "cursor-skills" }
    },
    {
      "id": "settings_templates",
      "source": {
        "type": "templateDir",
        "fromDir": "templates/shared/settings/templates",
        "toDir": "{{KIRO_DIR}}/settings/templates"
      },
      "when": { "agent": "cursor-skills" }
    }
  ]
}
